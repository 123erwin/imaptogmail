IMAP_HOST=imap.one.com
IMAP_PORT=993
IMAP_USERNAME=your-email@your-domain.com
IMAP_PASSWORD=your-imap-password
IMAP_USE_SSL=true

# Step 1 options
STEP1_ENABLE_MOVE=true
IMAP_SOURCE_FOLDER=INBOX
IMAP_MOVE_TO_FOLDER=ToGmail
IMAP_CREATE_TARGET_FOLDER=true
IMAP_DATE_FROM=2025-01-01
IMAP_DATE_TO=2025-12-31

# Step 2 options
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
# Comma separated: one or more source folders on IMAP
GMAIL_IMPORT_SOURCE_FOLDER=ToGmail,INBOX.2024.social
GMAIL_ENABLE_IMPORT=true
# Only a folder name (single level). It is created as subfolder under each source folder.
GMAIL_IMPORTED_MOVE_TO_FOLDER=verwerkt
GMAIL_MOVE_IMPORTED=true
GMAIL_LABELS=INBOX,Imported,OneCom
GMAIL_LABEL_STRATEGY=env
LABEL_MAPPING_FILE=label_mapping.json

# Logging
LOG_FILE=logs/imaptogmail.log
LOG_LEVEL=INFO
